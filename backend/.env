# Local development defaults (outside Docker)
DATABASE_URL=postgresql+asyncpg://pipeline_user:pipeline@127.0.0.1:5432/pipeline_db
PIPELINE_DATABASE_URL=postgresql+asyncpg://pipeline_user:pipeline@127.0.0.1:5432/pipeline_db
REDIS_URL=redis://127.0.0.1:6379/0

# Security
SECRET_KEY=your-super-secret-key-123
ALGORITHM=HS256
DEBUG=false

# Optional CORS override (JSON array or comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:8080"]
