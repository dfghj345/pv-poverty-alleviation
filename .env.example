# Backend / Pipeline shared runtime config
SECRET_KEY=change-this-secret-before-production
DEBUG=false
LOG_LEVEL=INFO
REDIS_URL=redis://redis:6379/0

# Preferred for docker-compose deployment: backend derives DATABASE_URL automatically.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=pv_poverty_alleviation

# Optional explicit DSN overrides for non-compose deployments
# DATABASE_URL=postgresql+asyncpg://admin:change-this-postgres-password@127.0.0.1:5432/pv_poverty_alleviation
# PIPELINE_DATABASE_URL=postgresql+asyncpg://admin:change-this-postgres-password@127.0.0.1:5432/pv_poverty_alleviation

# Optional CORS override (JSON array or comma-separated string)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://poverty.dpdns.org","http://8.139.7.171"]

# Optional pip mirror/build stability settings for China mainland servers
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_DEFAULT_TIMEOUT=180
PIP_RETRIES=10
