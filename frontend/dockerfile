FROM node:20-alpine

WORKDIR /app

ARG VITE_APP_AMAP_KEY
ARG VITE_APP_AMAP_SECURITY_CODE
ARG VITE_API_BASE_URL=/api/v1

ENV VITE_APP_AMAP_KEY=${VITE_APP_AMAP_KEY}
ENV VITE_APP_AMAP_SECURITY_CODE=${VITE_APP_AMAP_SECURITY_CODE}
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

CMD ["npm", "run", "build"]
